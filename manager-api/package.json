{
  "name": "manager-api",
  "version": "1.0.0",
  "description": "创意应用中心后端 API",
  "main": "src/index.js",
  "scripts": {
    "dev": "node src/index.js",
    "dev:watch": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:wait": "node scripts/waitForDb.js",
    "db:start": "docker compose -f ../docker-compose.yml up -d mysql",
    "db:stop": "docker compose -f ../docker-compose.yml down",
    "db:logs": "docker compose -f ../docker-compose.yml logs -f mysql",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset.js",
    "db:init": "npm run db:wait && npm run db:migrate && npm run db:seed",
    "db:bootstrap": "npm run db:start && npm run db:init"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0"
  },
  "devDependencies": {
    "morgan": "^1.10.1"
  }
}
